{
  "name": "rust-image-viewer",
  "version": "1.0.0",
  "description": "A lightweight image viewer built with Electron + Vue",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc -p electron/tsconfig.json",
    "electron:dev": "tsc -p electron/tsconfig.json && concurrently -k \"vite\" \"wait-on http://localhost:5173 && cross-env ELECTRON_DEV=1 electron .\"",
    "electron:build": "vite build && tsc -p electron/tsconfig.json && electron-builder",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit && tsc -p electron/tsconfig.json --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@vitejs/plugin-vue": "^6.0.5",
    "jszip": "^3.10.1",
    "sharp": "^0.33.0",
    "vue": "^3.5.32"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@vue/tsconfig": "^0.9.1",
    "concurrently": "^9.0.0",
    "cross-env": "^10.1.0",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vue-tsc": "^3.2.6",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.rustimageviewer.app",
    "productName": "Rust Image Viewer",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": "portable",
      "signAndEditExecutable": false,
      "forceCodeSigning": false
    }
  }
}
